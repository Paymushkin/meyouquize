NODE_ENV=production
APP_NETWORK_MODE=lan
PORT=4000

# LAN hosts from which browser clients will connect.
CLIENT_ORIGIN=http://192.168.1.10,http://quiz.local
CLIENT_ORIGIN_ALLOW_LAN=1

DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/meyouquize
CLUSTER_WORKERS=1
# REDIS_URL=redis://127.0.0.1:6379
# CLUSTER_WORKERS=auto

# Все админы — один JSON-массив (plain или ADMIN_ACCOUNTS_BASE64), см. корневой .env.example
# ADMIN_ACCOUNTS=[{"login":"admin","password":"REPLACE_WITH_STRONG_PASSWORD"},{"login":"Anna","password":"REPLACE_WITH_STRONG_PASSWORD"}]
ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_SESSION_HOURS=8
