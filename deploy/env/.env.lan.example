NODE_ENV=production
APP_NETWORK_MODE=lan
PORT=4000

# LAN hosts from which browser clients will connect.
CLIENT_ORIGIN=http://192.168.1.10,http://quiz.local
CLIENT_ORIGIN_ALLOW_LAN=1

DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/meyouquize
# REDIS_URL=redis://127.0.0.1:6379

ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# ADMIN_ACCOUNTS=[{"login":"operator2","password":"REPLACE_WITH_STRONG_PASSWORD"}]
ADMIN_SESSION_HOURS=8
