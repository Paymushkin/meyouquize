NODE_ENV=production
APP_NETWORK_MODE=internet
PORT=4000

# Frontend domain served by Caddy (comma-separated allowlist if needed).
CLIENT_ORIGIN=https://quiz.example.com
CLIENT_ORIGIN_ALLOW_LAN=0

# Runtime через PgBouncer (рекомендуется на VPS): порт 6432 + pgbouncer=true; миграции — DIRECT_URL на :5432.
# Пример: DATABASE_URL=postgresql://USER:PASSWORD@127.0.0.1:6432/meyouquize?pgbouncer=true&connection_limit=12
# DIRECT_URL=postgresql://USER:PASSWORD@127.0.0.1:5432/meyouquize
# Без PgBouncer: один и тот же хост:порт в обоих URL (оба :5432).
DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/meyouquize
DIRECT_URL=postgresql://USER:PASSWORD@DB_HOST:5432/meyouquize

# Один процесс по умолчанию. Мультиядро: поднимите Redis, затем раскомментируйте две строки ниже.
CLUSTER_WORKERS=1
# REDIS_URL=redis://127.0.0.1:6379
# CLUSTER_WORKERS=auto

# Heartbeat Socket.IO (мс). При нагрузке дефолт Engine.IO 20s часто даёт «ping timeout» в логах.
# SOCKET_IO_PING_TIMEOUT_MS=60000
# SOCKET_IO_PING_INTERVAL_MS=25000

# Под всплески join/submit: больше — меньше нагрузка на БД при пересчёте дашборда (реже обновление цифр).
# DASHBOARD_RESULTS_DEBOUNCE_MS=400
# Склейка пересчёта «онлайн» по сокетам (меньше fetchSockets подряд при массовом входе).
# QUIZ_ONLINE_COUNT_DEBOUNCE_MS=300

# Все админы — один JSON-массив (лучше ADMIN_ACCOUNTS_BASE64), см. корневой .env.example
# ADMIN_ACCOUNTS=[{"login":"admin","password":"REPLACE_WITH_STRONG_PASSWORD"},{"login":"Anna","password":"REPLACE_WITH_STRONG_PASSWORD"}]
ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_SESSION_HOURS=8
