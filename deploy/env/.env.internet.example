NODE_ENV=production
APP_NETWORK_MODE=internet
PORT=4000

# Frontend domain served by Caddy (comma-separated allowlist if needed).
CLIENT_ORIGIN=https://quiz.example.com
CLIENT_ORIGIN_ALLOW_LAN=0

DATABASE_URL=postgresql://USER:PASSWORD@DB_HOST:5432/meyouquize
# REDIS_URL=redis://127.0.0.1:6379

ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
# ADMIN_ACCOUNTS=[{"login":"operator2","password":"REPLACE_WITH_STRONG_PASSWORD"}]
ADMIN_SESSION_HOURS=8
