# Конфигурация мероприятия в локальной Wi‑Fi (200–300 участников на одном хосте).
# Инициализация: npm run event:init  →  deploy/env/.env.runtime + корневой .env
# Запуск:       npm run event:start

NODE_ENV=production
APP_NETWORK_MODE=lan
PORT=4000

# Подставляется скриптом event:init (ipconfig getifaddr en0 / аналог на Linux).
LAN_HOST=__LAN_HOST__
CLIENT_ORIGIN=http://__LAN_HOST__
CLIENT_ORIGIN_ALLOW_LAN=1

# Postgres на этом же Mac. connection_limit ≈ 6 на воркер (при CLUSTER_WORKERS=auto до 8 воркеров).
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/meyouquize?connection_limit=6
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/meyouquize

# Обязательно при CLUSTER_WORKERS>1 (Socket.IO между процессами).
REDIS_URL=redis://127.0.0.1:6379
# auto = min(число ядер, 8); на 10‑ядерном Mac будет 8 воркеров.
CLUSTER_WORKERS=auto

# Стабильнее при сотнях телефонов в одной Wi‑Fi.
SOCKET_IO_PING_TIMEOUT_MS=60000
SOCKET_IO_PING_INTERVAL_MS=25000
DASHBOARD_RESULTS_DEBOUNCE_MS=280
QUIZ_ONLINE_COUNT_DEBOUNCE_MS=400

ADMIN_LOGIN=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
ADMIN_SESSION_HOURS=12

# API/Socket: в production-сборке по умолчанию тот же origin, что в адресной строке (Caddy :80).
# VITE_API_URL / VITE_SOCKET_URL — только если API на другом хосте.
# QR и «Ссылка на ивент» берут window.location.origin; не нужно дублировать IP в VITE_APP_ORIGIN.
# Если админка на localhost, а QR для телефонов в LAN — задайте:
# VITE_PUBLIC_PLAYER_ORIGIN=http://__LAN_HOST__
