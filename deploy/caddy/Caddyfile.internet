{$DOMAIN} {
  encode zstd gzip

  # /socket.io/* не матчит путь /socket.io — иначе long-polling попадает в SPA (index.html вместо JS).
  @api path /api/* /socket.io*
  handle @api {
    reverse_proxy 127.0.0.1:4000
  }

  handle {
    root * /opt/meyouquize/current/client/dist
    try_files {path} /index.html
    file_server
  }
}
