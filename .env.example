PORT=4000
APP_NETWORK_MODE=lan
# Список Origin фронта (через запятую). Для планшета в Wi‑Fi проще оставить дефолт + см. ниже.
CLIENT_ORIGIN=http://localhost:5173,http://192.168.1.100:5173
# В LAN-режиме (APP_NETWORK_MODE=lan) можно разрешить origin из private сети и localhost.
# Для internet-режима игнорируется и всегда используется только CLIENT_ORIGIN whitelist.
# Отключить даже в LAN: CLIENT_ORIGIN_ALLOW_LAN=0
# CLIENT_ORIGIN_ALLOW_LAN=1
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meyouquize
# REDIS_URL=redis://localhost:6379
ADMIN_LOGIN=change-me-admin
ADMIN_PASSWORD=change-me-strong-password
# Дополнительные админы (JSON-массив). Только в секретном .env на сервере, в git не коммитить.
# Если в пароле есть $ или ! — надёжнее через base64 (одна строка, без кавычек в JSON на диске):
# echo -n '[{"login":"Anna","password":"…"}]' | base64
# ADMIN_ACCOUNTS_BASE64=W3sibG9naW4iOiJBbm5hIiwicGFzc3dvcmQiOiLi…
# ADMIN_ACCOUNTS=[{"login":"operator2","password":"your-secret-here"}]
ADMIN_SESSION_HOURS=8
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_APP_ORIGIN=http://localhost:5173
