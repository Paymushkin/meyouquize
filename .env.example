PORT=4000
APP_NETWORK_MODE=lan
# Список Origin фронта (через запятую). Для планшета в Wi‑Fi проще оставить дефолт + см. ниже.
CLIENT_ORIGIN=http://localhost:5173,http://192.168.1.100:5173
# В LAN-режиме (APP_NETWORK_MODE=lan) можно разрешить origin из private сети и localhost.
# Для internet-режима игнорируется и всегда используется только CLIENT_ORIGIN whitelist.
# Отключить даже в LAN: CLIENT_ORIGIN_ALLOW_LAN=0
# CLIENT_ORIGIN_ALLOW_LAN=1
# Runtime: через PgBouncer — порт 6432 и параметр pgbouncer=true (см. deploy/DEPLOYMENT.md §PgBouncer).
# Локально без пула: оба URL одинаковые на :5432.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/meyouquize
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/meyouquize
# REDIS_URL=redis://localhost:6379

# --- Админы: один JSON-массив всех учёток (только в секретном .env на сервере, в git не коммитить) ---
# Вариант A (рекомендуется в production): весь массив в base64 — пароли могут содержать $, ! и т.д.
# echo -n '[{"login":"admin","password":"…"},{"login":"Anna","password":"…"}]' | base64
# ADMIN_ACCOUNTS_BASE64=…вставь_вывод_base64_одной_строкой…
#
# Вариант B (локально / без спецсимволов в паролях): plain JSON в одной строке
# ADMIN_ACCOUNTS=[{"login":"admin","password":"your-secret"},{"login":"Anna","password":"other-secret"}]
#
# Если ADMIN_ACCOUNTS и ADMIN_ACCOUNTS_BASE64 не заданы — используются пара ниже (один админ).
ADMIN_LOGIN=change-me-admin
ADMIN_PASSWORD=change-me-strong-password

ADMIN_SESSION_HOURS=8
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
VITE_APP_ORIGIN=http://localhost:5173
