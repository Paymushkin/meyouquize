generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quiz {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  accessToken String
  status      QuizStatus    @default(DRAFT)
  /** Снимок public view (режим экрана, брендирование, настройки облака) для комнаты */
  publicView  Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  subQuizzes  SubQuiz[]
  questions   Question[]
  participants Participant[]
  answers     Answer[]
  speakerQuestions SpeakerQuestion[]
}

model SubQuiz {
  id                   String     @id @default(cuid())
  quizId               String
  quiz                 Quiz       @relation(fields: [quizId], references: [id], onDelete: Cascade)
  title                String     @default("Квиз")
  sortOrder            Int        @default(0)
  currentQuestionIndex Int        @default(0)
  questions            Question[]

  @@index([quizId])
}

model Question {
  id          String        @id @default(cuid())
  quizId      String
  quiz        Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  /** null — отдельное голосование комнаты */
  subQuizId   String?
  subQuiz     SubQuiz?      @relation(fields: [subQuizId], references: [id], onDelete: Cascade)
  text        String
  type        QuestionType
  order       Int
  points      Int           @default(1)
  maxAnswers  Int           @default(1)
  isActive    Boolean       @default(false)
  isClosed    Boolean       @default(false)
  /** POLL: баллы не начисляются */
  scoringMode ScoringMode   @default(QUIZ)
  /** Голосования комнаты: показывать на проекторе ники первых верно ответивших (если включено глобально). */
  projectorShowFirstCorrect Boolean @default(true)
  /** Сколько первых верно ответивших показывать на проекторе (1–20), если projectorShowFirstCorrect. */
  projectorFirstCorrectWinnersCount Int @default(1)
  /** Для RANKING: баллы за совпадение на каждой позиции (индекс 0 = верх списка «лучший»). Null — старый режим: весь вопрос даёт `points` только при полном совпадении. */
  rankingPointsByRank Json?
  /** Для RANKING: что показывать на проекторе по вариантам */
  rankingProjectorMetric RankingProjectorMetric @default(AVG_RANK)
  /** RANKING: квиз (эталон, зачёт) или жюри (нет верного ответа, баллы только для статистики) */
  rankingKind RankingKind @default(QUIZ)
  /** Для RANKING: пользовательская подсказка на экране игрока (если null — используется текст по умолчанию). */
  rankingPlayerHint String?
  /** Когда вопрос был выведен на экран для ответов (для подсчёта responseMs). */
  activatedAt DateTime?
  options     Option[]
  answers     Answer[]

  @@index([quizId])
  @@index([subQuizId])
}

model Option {
  id         String   @id @default(cuid())
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text       String
  isCorrect  Boolean  @default(false)
  /** Порядок варианта в вопросе (0 = лучший при ранжировании). Для SINGLE/MULTI задаётся при сохранении. */
  sortOrder  Int      @default(0)
}

model Participant {
  id        String   @id @default(cuid())
  quizId    String
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  deviceId  String
  nickname  String
  createdAt DateTime @default(now())
  answers   Answer[]
  speakerQuestions SpeakerQuestion[]
  speakerQuestionLikes SpeakerQuestionLike[]
  speakerQuestionDislikes SpeakerQuestionDislike[]
  speakerQuestionReactions SpeakerQuestionReaction[]

  @@unique([quizId, deviceId])
  @@index([quizId])
}

model SpeakerQuestion {
  id            String                @id @default(cuid())
  quizId         String
  quiz           Quiz                  @relation(fields: [quizId], references: [id], onDelete: Cascade)
  participantId  String
  participant    Participant           @relation(fields: [participantId], references: [id], onDelete: Cascade)
  speakerName    String
  text           String
  isVisibleToUsers Boolean              @default(true)
  status         SpeakerQuestionStatus @default(PENDING)
  isOnScreen     Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  likes          SpeakerQuestionLike[]
  dislikes       SpeakerQuestionDislike[]
  reactions      SpeakerQuestionReaction[]

  @@index([quizId, createdAt])
  @@index([quizId, status, createdAt])
  @@index([quizId, isOnScreen, createdAt])
}

model SpeakerQuestionReaction {
  id                String          @id @default(cuid())
  speakerQuestionId String
  speakerQuestion   SpeakerQuestion @relation(fields: [speakerQuestionId], references: [id], onDelete: Cascade)
  participantId     String
  participant       Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  reaction          String
  createdAt         DateTime        @default(now())

  @@unique([speakerQuestionId, participantId, reaction])
  @@index([speakerQuestionId])
  @@index([participantId])
}

model SpeakerQuestionLike {
  id                String         @id @default(cuid())
  speakerQuestionId String
  speakerQuestion   SpeakerQuestion @relation(fields: [speakerQuestionId], references: [id], onDelete: Cascade)
  participantId     String
  participant       Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([speakerQuestionId, participantId])
  @@index([participantId])
}

model SpeakerQuestionDislike {
  id                String          @id @default(cuid())
  speakerQuestionId String
  speakerQuestion   SpeakerQuestion @relation(fields: [speakerQuestionId], references: [id], onDelete: Cascade)
  participantId     String
  participant       Participant     @relation(fields: [participantId], references: [id], onDelete: Cascade)
  createdAt         DateTime        @default(now())

  @@unique([speakerQuestionId, participantId])
  @@index([participantId])
}

model Answer {
  id                String      @id @default(cuid())
  quizId            String
  quiz              Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId        String
  question          Question    @relation(fields: [questionId], references: [id], onDelete: Cascade)
  participantId     String
  participant       Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  selectedOptionIds String
  isCorrect         Boolean
  scoreAwarded      Int         @default(0)
  /** Время ответа в миллисекундах относительно момента активации вопроса. */
  responseMs        Int         @default(0)
  submittedAt       DateTime    @default(now())

  @@unique([questionId, participantId])
  @@index([quizId])
  @@index([questionId])
  @@index([participantId])
  /** Выборки лидербордов и getParticipantAnswersMap по комнате + участнику */
  @@index([quizId, participantId])
  /** Для tie-break в лидербордах: score DESC, totalResponseMs ASC. */
  @@index([quizId, participantId, responseMs])
}

model AdminSession {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

enum ScoringMode {
  POLL
  QUIZ
}

/** Метрика на проекторе для вопросов RANKING */
enum RankingProjectorMetric {
  AVG_RANK
  AVG_SCORE
  TOTAL_SCORE
}

/** RANKING: квиз с эталоном или «жюри» без правильного ответа */
enum RankingKind {
  QUIZ
  JURY
}

enum QuestionType {
  SINGLE
  MULTI
  TAG_CLOUD
  RANKING
}

enum QuizStatus {
  DRAFT
  LIVE
  FINISHED
}

enum SpeakerQuestionStatus {
  PENDING
  APPROVED
  REJECTED
}
