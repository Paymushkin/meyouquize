{
  "name": "server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/src/index.js",
    "build": "prisma generate && tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "dotenv -e ../.env -- prisma migrate dev",
    "prisma:migrate:deploy": "dotenv -e ../.env -- prisma migrate deploy",
    "loadtest:socket": "node scripts/socket-load-burst.mjs",
    "loadtest:k6": "k6 run ../loadtest/k6-quiz-health.js"
  },
  "dependencies": {
    "@meyouquize/shared": "*",
    "@prisma/client": "^6.6.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "multer": "^2.1.1",
    "pdfkit": "^0.18.0",
    "redis": "^5.11.0",
    "socket.io": "^4.8.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.13.14",
    "@types/pdfkit": "^0.17.6",
    "@types/supertest": "^6.0.3",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.6.0",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.1"
  }
}
